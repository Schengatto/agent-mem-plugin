# ═══════════════════════════════════════════════════════════════════════════
# MemoryMesh — .env.example
# ═══════════════════════════════════════════════════════════════════════════
#
# Copia questo file in .env e compila i campi.
#   cp .env.example .env
#   # Genera secret: make secrets-gen
#
# SICUREZZA:
#   - NON committare .env nel git. È già in .gitignore.
#   - Tutti i campi marcati CHANGE ME devono essere sostituiti.
#   - Usa `openssl rand -hex 32` per generare secret casuali robusti.
#
# ═══════════════════════════════════════════════════════════════════════════

# ─── Profile Deployment ──────────────────────────────────────────────────
# lan    → home server LAN, no TLS obbligatorio, mDNS attivo
# vpn    → LAN + Tailscale/WireGuard, TLS interno, mDNS attivo
# public → internet-facing via Cloudflare Tunnel / reverse proxy, TLS obbligatorio,
#          HSTS preload, fail2ban, rate limit aggressivo
MEMORYMESH_DEPLOYMENT=lan

# Hostname pubblico del server. Per profile=lan può restare mm.local.
# Per profile=vpn/public deve essere il DNS name pubblico (ACME cert generato per questo).
MEMORYMESH_HOSTNAME=mm.local

# Email admin per Let's Encrypt (richiesta solo profile=vpn/public)
ADMIN_EMAIL=

# Timezone (per CRON distillation e log)
TZ=UTC

# ─── Secrets core ────────────────────────────────────────────────────────
# SECRET_KEY: usato per HKDF derivation — session cookie signing, TOTP encrypt,
# audit HMAC. NON cambiare mai dopo il primo setup (invaliderebbe TOTP cifrati).
# Genera con: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── PostgreSQL ──────────────────────────────────────────────────────────
# Utente amministrativo (postgres superuser). Usato SOLO per init-db.sql.
# La applicazione usa mm_api/mm_worker/mm_admin con grant limitati.
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=CHANGE_ME_random_password

# Password per i 3 DB user creati da init-db.sql
# (application-level, accesso limitato per separation of duty)
PG_MM_API_PASSWORD=CHANGE_ME_random_password
PG_MM_WORKER_PASSWORD=CHANGE_ME_random_password
PG_MM_ADMIN_PASSWORD=CHANGE_ME_random_password

# ─── Redis ───────────────────────────────────────────────────────────────
# Password obbligatoria anche su network interno (defense in depth).
REDIS_PASSWORD=CHANGE_ME_random_password

# ─── Caddy / Porte ───────────────────────────────────────────────────────
# Porte bind sull'host. Default: 80 + 443.
# Cambia se hai già qualcosa in ascolto su queste porte.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ═══════════════════════════════════════════════════════════════════════════
# LLM / Embedding — provider-agnostic (vedi DEPENDENCIES.md ADR-014, 015)
# ═══════════════════════════════════════════════════════════════════════════
#
# PROFILE A (default, cloud): Gemini per LLM + Embedding. Zero Ollama container.
#   - RAM server ~2.75 GB. Gira ovunque (RPi5, NAS, VM $6/mese).
#   - Costo tipico: <$1/mese single user, <$3/mese famiglia.
#   - Privacy: observation content va a Google. Secret scrubbing mitiga.
#
# PROFILE B (ibrido): Gemini LLM + Ollama embedding locale.
#   - RAM server ~3.65 GB. Embedding privacy-preserving.
#   - Docker: avvia con `docker compose --profile ollama up`
#
# PROFILE C (privacy-strict): Ollama Qwen locale + Ollama embedding locale.
#   - RAM server ~3.65 GB baseline, ~9.15 GB picco distillazione.
#   - Zero dati in cloud. Richiede mini-PC 16GB.

# ─── LLM Provider ────────────────────────────────────────────────────────
# gemini | ollama | openai | anthropic
MEMORYMESH_LLM_PROVIDER=gemini

# Modello specifico per il provider scelto
# gemini:    gemini-2.5-flash (default), gemini-2.5-pro, gemini-3-flash-preview
# ollama:    qwen3.5:9b, qwen3.5:4b (più leggero), llama3.3:8b
# openai:    gpt-5-mini, gpt-4.1-mini, gpt-4o-mini
# anthropic: claude-haiku-4-5, claude-sonnet-4-6
MEMORYMESH_LLM_MODEL=gemini-2.5-flash

# ─── Embedding Provider ──────────────────────────────────────────────────
# gemini | ollama
MEMORYMESH_EMBED_PROVIDER=gemini

# Modello specifico
# gemini: text-embedding-004 (default, 768d)
# ollama: nomic-embed-text-v2-moe (default, 768d Matryoshka)
MEMORYMESH_EMBED_MODEL=text-embedding-004

# ─── API Key Cloud Providers ─────────────────────────────────────────────
# Richiesta per il provider selezionato (LLM e/o EMBED).
# Lascia vuota se non usi il provider (es. se LLM=ollama AND EMBED=ollama,
# nessuna API key cloud serve).

# Obbligatoria se LLM_PROVIDER=gemini OR EMBED_PROVIDER=gemini
# Ottieni gratis da https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opzionali (opt-in se cambi provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Budget Cap Hard (ADR-016) ────────────────────────────────────────────
# Daily token cap per prevenire bill shock. Atomic counter Redis.
# Se superato: operation skip + audit + ntfy admin.
#
# Raccomandati:
#   500_000     → default, copre uso intenso single user
#   2_000_000   → team 3-5 device attivi
#   50_000      → ultra-conservativo (~1 sessione Claude Code tipica)
#   0           → disabilita cap (sconsigliato su profile PUBLIC)
MEMORYMESH_LLM_DAILY_TOKEN_CAP=500000

# ─── Reranker (SEMPRE locale, non-configurable provider) ─────────────────
# Jina reranker v2 multilingual. ~350MB RAM resident.
# Disabilitabile con SEARCH_RERANK_ENABLED=false sopra.
RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual

# ─── Ollama (solo Profile B o C) ─────────────────────────────────────────
# Modelli da pullare al primo avvio se MEMORYMESH_*_PROVIDER=ollama.
# Ignorato se entrambi i provider sono cloud.
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_DISTILL_MODEL=qwen3.5:9b

# ─── Feature Flag ────────────────────────────────────────────────────────
# Abilita cross-encoder rerank (Strategia 15). Richiede sentence-transformers
# nel container (~350MB RAM extra). Disattiva se mini PC ha poca RAM.
SEARCH_RERANK_ENABLED=true

# Auto-estrazione vocab da observation nella distillazione notturna.
VOCAB_EXTRACT_ENABLED=true

# Logging dettagliato accessi observation per fingerprint precision (Strategia 16).
# Overhead scrittura non banale; abilita solo dopo 2 settimane di uso.
FP_LOGGING_ENABLED=false

# ─── Distillation ────────────────────────────────────────────────────────
# Schedule CRON (UTC). Default 03:00 UTC.
DISTILLATION_CRON=0 3 * * *

# ─── Version Tag ─────────────────────────────────────────────────────────
# Usato come tag immagine in `docker compose build`.
# Auto-settato a dev in assenza; in prod settato dal CI tag.
VERSION=dev

# ═══════════════════════════════════════════════════════════════════════════
# NOTE OPERATIVE
# ═══════════════════════════════════════════════════════════════════════════
#
# BACKUP ENCRYPTION KEY (Fase 12):
#   Il backup è cifrato con age. La chiave PUBLIC è nel server
#   (/etc/memorymesh/backup-pubkey.age), la chiave PRIVATA vive SOLO fuori
#   dal server (password manager, USB crittato). NON metterla in .env.
#
# ROTAZIONE SECRET_KEY:
#   Cambiare SECRET_KEY invalida i TOTP cifrati degli admin. Se devi ruotarla:
#   1. Ogni admin fa re-enroll TOTP (richiede recovery code per login)
#   2. Poi aggiorna SECRET_KEY e riavvia
#   Evita di ruotare. Se compromessa, ruota TUTTO (DB + chiavi + admin).
#
# TLS SU LAN:
#   Profile=lan usa HTTP di default. Se vuoi TLS anche su LAN:
#   1. MEMORYMESH_DEPLOYMENT=vpn
#   2. Genera internal CA + cert (o usa step-ca)
#   3. Mount cert in caddy volume
#
# MULTI-USER:
#   Il primo utente viene creato al pair di un device.
#   Per aggiungere membri famiglia/team: admin UI → Users → Invite.
#
# ═══════════════════════════════════════════════════════════════════════════
